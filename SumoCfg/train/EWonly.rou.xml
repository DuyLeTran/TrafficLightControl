<?xml version="1.0" encoding="UTF-8"?>

<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!-- East flows -->

    
    <flow id="E1W_bike"      type="motorbike"     begin="0" from="E1_to_E" to="C_to_W"   departLane="0" arrivalLane="1" number="20"    period="5.0"     color="255,50,0"/>
    <flow id="E2W_bike"      type="motorbike"     begin="0" from="E2_to_E" to="C_to_W"   departLane="0" arrivalLane="1" number="20"    period="5.0"     color="255,0,200"/>
   
    <flow id="E1W_car_1"      type="car"          begin="0" from="E1_to_E" to="C_to_W"   departLane="0" arrivalLane="1" number="15"      period="10.0"     color="200,80,50"/>
    <flow id="E2W_car_1"      type="car"          begin="0" from="E2_to_E" to="C_to_W"   departLane="0" arrivalLane="1" number="15"      period="10.0"     color="180,80,120"/>
    
    
    <!-- West flows -->

  
    <flow id="WE1_bike"      type="motorbike"    begin="0" from="W_to_C" to="E_to_E1"   departLane="0" arrivalLane="1" number="20"    period="5.0"     color="30,0,255"/>
    <flow id="WE2_bike"      type="motorbike"    begin="0" from="W_to_C" to="E_to_E2"   departLane="0" arrivalLane="1" number="20"    period="5.0"     color="60,0,255"/>
    
    <flow id="WE1_car"      type="car"          begin="0" from="W_to_C" to="E_to_E1"   departLane="0" arrivalLane="1" number="15"      period="10.0"     color="150,80,200"/>
    <flow id="WE2_car"      type="car"          begin="0" from="W_to_C" to="E_to_E2"   departLane="0" arrivalLane="1" number="15"      period="10.0"     color="120,50,180"/>

</routes>
